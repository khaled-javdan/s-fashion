generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                String           @id @default(cuid())
  slug              String           @unique
  nameAr            String
  nameEn            String
  descAr            String?          @db.Text
  descEn            String?          @db.Text
  // "Additional information" block shown in the PDP tabs (care, materials,
  // styling notes). Free-form per product; either locale may be left empty.
  additionalInfoAr  String?          @db.Text
  additionalInfoEn  String?          @db.Text
  priceFils         Int
  compareAtFils     Int?
  // Unit cost (what we pay the supplier), in fils. Required. Snapshotted onto
  // OrderItem at checkout, so changing it here never rewrites the profit of
  // past orders.
  costPriceFils     Int
  // Shipping weight in grams. Optional; null/0 means the product adds nothing to
  // the cart's weight, so it never triggers a per-kg shipping surcharge. Used by
  // `resolveShipping` together with each country's per-kg rate + free-weight
  // threshold to price heavier parcels.
  weightGrams       Int?
  // Optional per-product size chart override. When null the storefront falls
  // back to the global `size_chart.cm` setting. Shape mirrors that setting:
  // { unit: "cm", rows: [{ size, bust, waist, hips, length }] }.
  sizeChart         Json?
  isActive          Boolean          @default(true)
  isFinalSale       Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  variants          ProductVariant[]
  images            ProductImage[]
  reviews           Review[]

  @@index([isActive, createdAt])
}

model ProductVariant {
  id          String      @id @default(cuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorNameAr String?
  colorNameEn String?
  colorHex    String?
  size        Size
  stock       Int         @default(0)
  sku         String?     @unique
  /**
   * Soft-delete flag. A variant becomes archived when an admin removes it from
   * the editor BUT it has existing OrderItem references — Postgres blocks the
   * hard delete on the OrderItem FK, so we keep the row to preserve order
   * history and hide it from the storefront + admin form. Re-adding the same
   * (colorHex, size) unarchives the row instead of creating a duplicate.
   */
  isArchived  Boolean     @default(false)
  orderItems  OrderItem[]

  @@unique([productId, colorHex, size])
  @@index([productId])
  @@index([productId, isArchived])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altAr     String?
  altEn     String?
  /**
   * Optional color this photo depicts, matched to a variant's colorHex.
   */
  colorHex  String?
  position  Int     @default(0)

  @@index([productId, position])
}

/**
 * A deduplicated customer, keyed on verified E.164 phone. Upserted at order
 * creation (the OTP has already passed by then, so the phone is real). Holds
 * the latest contact/address snapshot plus marketing-consent state for future
 * WhatsApp/offer campaigns. Lifetime stats (order count, total spent) are
 * derived from `orders` at read time — intentionally not denormalised here.
 */
model Customer {
  id               String    @id @default(cuid())
  phone            String    @unique // E.164, e.g. +971501234567
  name             String
  email            String?
  locale           String // "ar" or "en" — last locale the customer used
  // Latest delivery snapshot (refreshed on each order).
  country          String?   @default("AE") // ISO 3166-1 alpha-2, e.g. "AE", "SA"
  emirate          Emirate? // UAE-only sub-region; null for other countries
  city             String?
  addressLine1     String?
  addressLine2     String?
  // Marketing consent. `marketingConsent` is the live flag; the timestamps
  // record when it was granted / revoked, and `consentSource` how (e.g.
  // "checkout"). Consent is only ever granted implicitly — never auto-revoked.
  marketingConsent Boolean   @default(false)
  consentAt        DateTime?
  unsubscribedAt   DateTime?
  consentSource    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([marketingConsent])
  @@index([emirate])
}

model Order {
  id            String       @id @default(cuid())
  orderNumber   String       @unique
  status        OrderStatus  @default(PENDING_VERIFICATION)
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  customerName  String
  phone         String // E.164, e.g. +971501234567
  phoneVerified Boolean      @default(false)
  email         String?
  country       String       @default("AE") // ISO 3166-1 alpha-2, e.g. "AE", "SA"
  emirate       Emirate? // UAE-only sub-region; null for other countries
  city          String
  addressLine1  String
  addressLine2  String?
  notes         String?      @db.Text
  subtotalFils  Int
  shippingFils  Int
  // Order-level discount from an applied coupon (fils, base AED). 0 = none.
  // `totalFils` already nets this out: subtotal − discount + shipping.
  discountFils  Int          @default(0)
  totalFils     Int
  // Snapshot of the redeemed coupon (code is kept even if the coupon is later
  // deleted; the FK is set null on delete so history survives).
  couponCode    String?
  couponId      String?
  coupon        Coupon?      @relation(fields: [couponId], references: [id], onDelete: SetNull)
  // Display-currency snapshot. Money columns above stay in base AED fils; these
  // record the currency the customer saw and the AED→currency rate at order time.
  displayCurrency String     @default("AED")
  fxRate          Float      @default(1)
  locale        String // "ar" or "en"
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  confirmedAt   DateTime?
  shippedAt     DateTime?
  deliveredAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  // Notification delivery stamps (null = not yet sent). These make the
  // fire-and-forget order notifications durable: a retry cron re-sends any
  // order still missing a stamp, so a transient Telegram/email failure never
  // silently loses an order.
  adminNotifiedAt   DateTime? // Telegram owner alert sent at
  customerEmailedAt DateTime? // Resend confirmation email sent at
  customerSmsedAt   DateTime? // Twilio SMS order confirmation sent at
  items         OrderItem[]
  events        OrderEvent[]
  redemption    CouponRedemption?

  @@index([status, createdAt])
  @@index([phone])
  @@index([customerId])
  @@index([country])
}

model OrderItem {
  // snapshot all fields at order time — never read from current Product
  id            String         @id @default(cuid())
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  productNameAr String
  productNameEn String
  colorNameAr   String?
  colorNameEn   String?
  size          Size
  unitPriceFils Int
  // Unit cost snapshot at order time (fils). Defaults to 0 for orders placed
  // before cost tracking existed / products with no cost set.
  unitCostFils  Int            @default(0)
  quantity      Int

  @@index([orderId])
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String // "status_change" | "note" | "courier_assigned" | "system"
  payload   Json
  actorId   String? // AdminUser.id, null = system
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(STAFF)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model OtpAttempt {
  id        String   @id @default(cuid())
  phone     String
  ip        String
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
  @@index([ip, createdAt])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

/**
 * Admin-curated customer review / testimonial. The store launches with no
 * organic reviews, so these are entered by hand from real social-media feedback.
 * `productId` is optional: a review tied to a product powers that product's
 * rating + PDP reviews; an untied review is a general site testimonial. `body`
 * is stored as-written (not translated). Reviews with `imageUrl` drive the home
 * UGC photo strip; `featured` opts a review into the home testimonials block.
 */
model Review {
  id           String    @id @default(cuid())
  productId    String?
  product      Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  rating       Int // 1–5
  authorName   String
  authorHandle String? // e.g. "@instagram_handle"
  authorEmail  String? // captured on customer submissions (admin contact only, never shown)
  body         String?   @db.Text
  source       String? // "instagram" | "tiktok" | "google" | "website" | ...
  imageUrl     String? // screenshot / customer photo (drives the UGC strip)
  featured     Boolean   @default(false) // show on the home page
  isVisible    Boolean   @default(true)
  // Customer-submitted reviews land here with isVisible=false (moderation queue);
  // admin-curated reviews are created with isVisible=true. Drives the pending count.
  isCustomerSubmitted Boolean @default(false)
  displayDate  DateTime? // the original review date (for display/ordering)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([productId, isVisible])
  @@index([featured, isVisible])
  @@index([isCustomerSubmitted, isVisible])
}

/**
 * A discount code. Money is base-AED fils. `value` is a percentage (1–100) for
 * PERCENT or a fils amount for FIXED. `timesRedeemed` is incremented atomically
 * inside the order transaction (a conditional update guards `maxRedemptions`).
 */
model Coupon {
  id              String             @id @default(cuid())
  code            String             @unique // stored UPPERCASE-normalized
  type            CouponType
  value           Int // PERCENT: 1–100; FIXED: fils
  minSubtotalFils Int                @default(0)
  maxDiscountFils Int? // cap for PERCENT coupons
  firstOrderOnly  Boolean            @default(false)
  maxRedemptions  Int? // global cap (null = unlimited)
  perCustomerLimit Int?              @default(1) // per-phone cap (null = unlimited)
  timesRedeemed   Int                @default(0)
  startsAt        DateTime?
  expiresAt       DateTime?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  redemptions     CouponRedemption[]
  orders          Order[]

  @@index([isActive])
}

/**
 * One row per coupon use, written inside the order-creation transaction. The
 * unique `orderId` makes createOrder retries idempotent; the (couponId, phone)
 * index backs the per-customer limit check.
 */
model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  phone     String
  createdAt DateTime @default(now())

  @@index([couponId, phone])
}

enum Size {
  XS
  S
  M
  L
  XL
  XXL
  FREE
}

enum Emirate {
  ABU_DHABI
  DUBAI
  SHARJAH
  AJMAN
  UMM_AL_QUWAIN
  RAS_AL_KHAIMAH
  FUJAIRAH
}

enum AdminRole {
  OWNER
  STAFF
}

enum OrderStatus {
  PENDING_VERIFICATION
  NEW
  CONFIRMED
  SHIPPED
  DELIVERED
  REFUSED
  CANCELLED
}

enum CouponType {
  PERCENT
  FIXED
}
