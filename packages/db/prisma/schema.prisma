generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                String           @id @default(cuid())
  slug              String           @unique
  nameAr            String
  nameEn            String
  descAr            String?          @db.Text
  descEn            String?          @db.Text
  // "Additional information" block shown in the PDP tabs (care, materials,
  // styling notes). Free-form per product; either locale may be left empty.
  additionalInfoAr  String?          @db.Text
  additionalInfoEn  String?          @db.Text
  priceFils         Int
  compareAtFils     Int?
  // Unit cost (what we pay the supplier), in fils. Optional — used only for
  // profit analytics. Snapshotted onto OrderItem at checkout, so changing it
  // here never rewrites the profit of past orders.
  costPriceFils     Int?
  isActive          Boolean          @default(true)
  isFinalSale       Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  variants          ProductVariant[]
  images            ProductImage[]

  @@index([isActive, createdAt])
}

model ProductVariant {
  id          String      @id @default(cuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  colorNameAr String?
  colorNameEn String?
  colorHex    String?
  size        Size
  stock       Int         @default(0)
  sku         String?     @unique
  orderItems  OrderItem[]

  @@unique([productId, colorHex, size])
  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altAr     String?
  altEn     String?
  /**
   * Optional color this photo depicts, matched to a variant's colorHex.
   */
  colorHex  String?
  position  Int     @default(0)

  @@index([productId, position])
}

/**
 * A deduplicated customer, keyed on verified E.164 phone. Upserted at order
 * creation (the OTP has already passed by then, so the phone is real). Holds
 * the latest contact/address snapshot plus marketing-consent state for future
 * WhatsApp/offer campaigns. Lifetime stats (order count, total spent) are
 * derived from `orders` at read time — intentionally not denormalised here.
 */
model Customer {
  id               String    @id @default(cuid())
  phone            String    @unique // E.164, e.g. +971501234567
  name             String
  email            String?
  locale           String // "ar" or "en" — last locale the customer used
  // Latest delivery snapshot (refreshed on each order).
  country          String?   @default("AE") // ISO 3166-1 alpha-2, e.g. "AE", "SA"
  emirate          Emirate? // UAE-only sub-region; null for other countries
  city             String?
  addressLine1     String?
  addressLine2     String?
  // Marketing consent. `marketingConsent` is the live flag; the timestamps
  // record when it was granted / revoked, and `consentSource` how (e.g.
  // "checkout"). Consent is only ever granted implicitly — never auto-revoked.
  marketingConsent Boolean   @default(false)
  consentAt        DateTime?
  unsubscribedAt   DateTime?
  consentSource    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([marketingConsent])
  @@index([emirate])
}

model Order {
  id            String       @id @default(cuid())
  orderNumber   String       @unique
  status        OrderStatus  @default(PENDING_VERIFICATION)
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  customerName  String
  phone         String // E.164, e.g. +971501234567
  phoneVerified Boolean      @default(false)
  email         String?
  country       String       @default("AE") // ISO 3166-1 alpha-2, e.g. "AE", "SA"
  emirate       Emirate? // UAE-only sub-region; null for other countries
  city          String
  addressLine1  String
  addressLine2  String?
  notes         String?      @db.Text
  subtotalFils  Int
  shippingFils  Int
  totalFils     Int
  // Display-currency snapshot. Money columns above stay in base AED fils; these
  // record the currency the customer saw and the AED→currency rate at order time.
  displayCurrency String     @default("AED")
  fxRate          Float      @default(1)
  locale        String // "ar" or "en"
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  confirmedAt   DateTime?
  shippedAt     DateTime?
  deliveredAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  items         OrderItem[]
  events        OrderEvent[]

  @@index([status, createdAt])
  @@index([phone])
  @@index([customerId])
  @@index([country])
}

model OrderItem {
  // snapshot all fields at order time — never read from current Product
  id            String         @id @default(cuid())
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  productNameAr String
  productNameEn String
  colorNameAr   String?
  colorNameEn   String?
  size          Size
  unitPriceFils Int
  // Unit cost snapshot at order time (fils). Defaults to 0 for orders placed
  // before cost tracking existed / products with no cost set.
  unitCostFils  Int            @default(0)
  quantity      Int

  @@index([orderId])
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String // "status_change" | "note" | "courier_assigned" | "system"
  payload   Json
  actorId   String? // AdminUser.id, null = system
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(STAFF)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model OtpAttempt {
  id        String   @id @default(cuid())
  phone     String
  ip        String
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
  @@index([ip, createdAt])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

enum Size {
  XS
  S
  M
  L
  XL
  XXL
  FREE
}

enum Emirate {
  ABU_DHABI
  DUBAI
  SHARJAH
  AJMAN
  UMM_AL_QUWAIN
  RAS_AL_KHAIMAH
  FUJAIRAH
}

enum AdminRole {
  OWNER
  STAFF
}

enum OrderStatus {
  PENDING_VERIFICATION
  NEW
  CONFIRMED
  SHIPPED
  DELIVERED
  REFUSED
  CANCELLED
}
