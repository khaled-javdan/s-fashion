  "shipping": {
    "title": "Shipping & Delivery",
    "intro": "We deliver to all seven emirates of the UAE. Here's everything you need to know about getting your order to your door.",
    "fees_heading": "Delivery fees",
    "fees_flat": "A flat delivery fee of {flat} applies to every order, anywhere in the UAE.",
    "fees_free": "Enjoy free delivery on orders over {threshold}.",
    "sections": [
      {
        "heading": "Delivery times",
        "body": [
          "Orders placed before 4pm are processed the same business day; orders after that are processed the next business day.",
          "Delivery then takes 1–3 business days depending on your emirate."
        ],
        "items": [
          "Dubai, Sharjah & Ajman: 1–2 business days.",
          "Abu Dhabi, Al Ain, Ras Al Khaimah, Fujairah & Umm Al Quwain: 2–3 business days."
        ]
      },
      {
        "heading": "Cash on delivery",
        "body": [
          "Pay in cash when your order arrives — no card needed. Please have the exact amount ready, as our couriers may not carry change."
        ]
      },
      {
        "heading": "Order confirmation",
        "body": [
          "After you place an order, we'll reach out on WhatsApp to confirm your details before dispatch. This keeps your delivery smooth and avoids failed attempts."
        ]
      }
    ],
    "track_blurb": "Already placed an order? Follow its journey anytime.",
    "track_cta": "Track your order"
  },
  "returns": {
    "title": "Returns & Exchanges",
    "intro": "Not quite right? We want you to love what you wear. You can return or exchange most items within 14 days of delivery.",
    "sections": [
      {
        "heading": "Return window",
        "body": [
          "You have 14 days from the day your order arrives to request a return or exchange. Reach out before the window closes and we'll take care of the rest."
        ]
      },
      {
        "heading": "Condition of items",
        "body": [
          "To be eligible for a return, items must be:"
        ],
        "items": [
          "Unworn, unwashed and undamaged.",
          "With all original tags still attached.",
          "In their original packaging."
        ]
      },
      {
        "heading": "Non-returnable items",
        "body": [
          "For hygiene and fairness, the following can't be returned:"
        ],
        "items": [
          "Pierced jewellery such as earrings.",
          "Items marked as final sale."
        ]
      },
      {
        "heading": "How to request a return",
        "body": [
          "Message us on WhatsApp or use our contact page with your order number and a quick note on what you'd like to do. We'll arrange a pickup or guide you through the next steps."
        ]
      },
      {
        "heading": "Refunds",
        "body": [
          "Once we receive and inspect your return, we'll let you know it's approved. Cash-on-delivery orders are refunded by bank transfer within 5–7 business days of approval."
        ]
      },
      {
        "heading": "Exchanges",
        "body": [
          "Need a different size or colour? Let us know and, subject to availability, we'll arrange the swap. If your new choice differs in price, we'll settle the difference with you directly."
        ]
      }
    ]
  },
  "contact": {
    "title": "Contact Us",
    "intro": "Have a question about an order, a product, or anything else? We're always happy to help.",
    "whatsapp_heading": "WhatsApp",
    "whatsapp_desc": "The fastest way to reach us. Tap below and we'll reply during business hours.",
    "whatsapp_cta": "Chat on WhatsApp",
    "email_heading": "Email",
    "email_desc": "Prefer to write? Send us a message and we'll get back to you within one business day.",
    "hours_heading": "Business hours",
    "hours_note": "Messages received outside these hours will be answered the next business day.",
    "hours_fallback": "Sat–Thu, 10am – 10pm"
